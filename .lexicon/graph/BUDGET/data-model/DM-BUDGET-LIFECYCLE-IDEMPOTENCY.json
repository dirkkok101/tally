  "ref_code": "DM-BUDGET-LIFECYCLE-IDEMPOTENCY",
  "name": "BudgetLifecycleAndIdempotency",
  "description": [
    "Attributable state-transition evidence plus replay metadata that references immutable outcomes without copying financial payloads."
  ],
  "schema_def": [
    "budget_lifecycle_event",
    "- event_id: ULID text primary key",
    "- plan_id, revision_id",
    "- event_type: DraftCreated|RevisionActivated|RevisionSuperseded",
    "- actor_kind, actor_label: required attributable values",
    "- actor_run_id: nullable attribution value",
    "- reason: non-blank bounded text",
    "- occurred_at_utc: trusted instant",
    "- prior_status, resulting_status: closed nullable enums",
    "- replacement_revision_id: nullable ULID",
    "- event_sequence: positive per-plan integer",
    "Constraints: unique(plan_id,event_sequence); append-only; exact prior/result/replacement chain; no update/delete.",
    "",
    "budget_idempotency_record",
    "- key_digest: SHA-256 primary key",
    "- contract_version, operation_id, request_hash",
    "- state: Completed",
    "- plan_id, result_revision_id, prior_active_revision_id nullable",
    "- lifecycle_event_ids: canonical ordered stable references",
    "- result_hash",
    "- created_at_utc, completed_at_utc",
    "Constraints: module-wide key; same operation/request rehydrates the exact event-time mutation snapshot, never later live revision/category/period state; any mismatch conflicts; no request/response JSON or duplicate amounts."
  ],
