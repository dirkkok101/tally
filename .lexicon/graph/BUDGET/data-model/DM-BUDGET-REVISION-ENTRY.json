  "ref_code": "DM-BUDGET-REVISION-ENTRY",
  "name": "BudgetPlanRevisionAndEntry",
  "description": [
    "Immutable revision payload and exact category amounts, with separately mutable constrained lifecycle status."
  ],
  "schema_def": [
    "budget_plan_revision",
    "- revision_id: ULID text primary key",
    "- plan_id: foreign key",
    "- revision_number: positive integer",
    "- status: enum Draft|Active|Superseded",
    "- actor_kind, actor_label: required attributable values",
    "- actor_run_id: nullable attribution value",
    "- reason: non-blank bounded text",
    "- created_at_utc: trusted instant",
    "- category_contract_version: released semantic version",
    "- payload_hash: SHA-256 canonical payload",
    "- activated_at_utc, superseded_at_utc: nullable trusted instants",
    "- superseded_by_revision_id: nullable same-plan foreign key",
    "Constraints: unique(plan_id,revision_number); at most one Active per plan via partial unique index; status transitions only Draft->Active->Superseded; content, provenance, and hash columns immutable while constrained lifecycle columns change only during activation.",
    "",
    "budget_plan_entry",
    "- revision_id + category_id: composite primary key",
    "- planned_minor_units: Int64 >= 0",
    "Constraints: stable category ULID only; explicit zero row is preserved; omission has no row; no name snapshot; rows immutable; computed total is exact checked sum, not separately authoritative."
  ],
