  "ref_code": "DIAG-BUDGET-MUTATION-SEQUENCE",
  "title": "Replay-safe draft and activation mutation",
  "diagram_type": "sequence",
  "format": "mermaid",
  "content": [
    "sequenceDiagram",
    "  participant C as CLI caller",
    "  participant H as Budget command",
    "  participant L as Public LEDGER executor",
    "  participant B as budget.db",
    "  C->>H: typed request + key",
    "  H->>H: schema, owner, period and request validation",
    "  H->>B: lookup key digest/request hash",
    "  alt completed exact replay",
    "    B-->>H: immutable outcome references",
    "    H-->>C: prior logical result",
    "  else new request",
    "    H->>L: compatible current category evidence",
    "    L-->>H: active lifecycle evidence",
    "    H->>B: BEGIN IMMEDIATE",
    "    H->>B: recheck local state; append payload/events; update Active pointer if activation",
    "    H->>B: persist outcome references and COMMIT",
    "    H-->>C: stable mutation result",
    "  end"
  ],
