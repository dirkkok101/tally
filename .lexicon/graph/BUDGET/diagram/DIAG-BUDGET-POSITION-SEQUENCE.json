  "content": [
    "sequenceDiagram",
    "  participant C as Owner or INSIGHTS",
    "  participant Q as GetBudgetPositionQuery",
    "  participant B as budget.db",
    "  participant L as Public LEDGER actuals",
    "  participant P as BudgetPositionCalculator",
    "  C->>Q: explicit period + optional revision",
    "  Q->>B: bind selected immutable revision",
    "  alt no Active and no selector",
    "    Q-->>C: NoActiveBudgetPlanRevision",
    "  else selected revision",
    "    Q->>L: exact interval and budget-actual filters",
    "    loop every cursor page in same snapshot",
    "      L-->>Q: ordered items, totals, cursor/provenance",
    "    end",
    "    Q->>Q: verify compatibility, ordinals and full-set total",
    "    Q->>P: immutable plan + complete snapshot",
    "    P-->>Q: exact ordered reconciled position",
    "    Q-->>C: position + plan/category/LEDGER provenance",
    "  end"
  ],
