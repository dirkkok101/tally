  "ref_code": "DIAG-CORE-BFF-AUTHENTICATION",
  "title": "BFF Authentication Flow",
  "diagram_type": "sequence",
  "format": "mermaid",
  "content": [
    "sequenceDiagram",
    "    autonumber",
    "    participant B as Browser",
    "    participant BFF as Actions BFF",
    "    participant ID as Identity (OIDC)",
    "    participant R as Redis",
    "    participant API as Actions API",
    "",
    "    rect rgb(240,240,255)",
    "    Note over B,ID: Session Establishment",
    "    B->>BFF: GET /api/actions (no session cookie)",
    "    BFF-->>B: 302 Redirect to Identity<br/>/connect/authorize?response_type=code<br/>&client_id=nxgn.actions.web<br/>&scope=openid profile actions<br/>&code_challenge={S256}&code_challenge_method=S256&state={state}",
    "    B->>ID: Authorization Code + PKCE flow<br/>(user authenticates, selects tenant)",
    "    ID-->>B: 302 Redirect to /bff/callback<br/>?code={auth_code}&state={state}",
    "    B->>BFF: GET /callback?code=xxx",
    "    BFF->>ID: POST /connect/token<br/>grant_type=authorization_code<br/>code, code_verifier, client_id, client_secret",
    "    ID-->>BFF: Tokens<br/>access_token (JWT with tenant_id, language_id, sub)<br/>refresh_token, id_token",
    "    BFF->>R: Store session<br/>key session:{session_id}<br/>value {access_token, refresh_token, user_info}",
    "    BFF-->>B: Set-Cookie __Host-actions={encrypted_session_id}<br/>HttpOnly; Secure; SameSite=Strict; Path=/",
    "    end",
    "",
    "    rect rgb(240,255,240)",
    "    Note over B,API: Authenticated Request",
    "    B->>BFF: GET /api/actions<br/>Cookie __Host-actions={...}",
    "    BFF->>API: GET /api/v1/actions<br/>Authorization Bearer {JWT from Redis session}<br/>(BFF strips any inbound Authorization from browser)",
    "    end",
    ""
  ],
