  "content": [
    "sequenceDiagram",
    "    autonumber",
    "    participant R as Requestor Browser",
    "    participant BFF",
    "    participant API as Actions API",
    "    participant DB as PostgreSQL",
    "    participant W as Worker Browser",
    "",
    "    rect rgb(240,240,255)",
    "    Note over R,DB: Request Phase",
    "    R->>API: POST /api/actions/{id}/consultations (via BFF)<br/>Body {contributor_id, contributor_role, input_prompt}",
    "    API->>DB: INSERT consultation<br/>status='requested', requested_by=actor_id (RLS)",
    "    API->>DB: INSERT audit_event<br/>consultation.requested",
    "    API-->>R: 201 Created<br/>Body ConsultationDTO",
    "    end",
    "",
    "    rect rgb(240,255,240)",
    "    Note over W,DB: Response Phase",
    "    W->>API: PUT /api/actions/{id}/consultations/{cid} (via BFF)<br/>Body {response_text}",
    "    API->>DB: UPDATE consultation<br/>SET status='responded', response=@text, responded_at=now()<br/>WHERE id=@cid AND contributor_id=@actor_id",
    "    end",
    "",
    "    rect rgb(255,240,240)",
    "    Note over R,DB: Acknowledgement Phase",
    "    R->>API: PUT /api/actions/{id}/consultations/{cid} (via BFF)<br/>Body {disposition: \"incorporated\" or \"not_incorporated\"}",
    "    API->>DB: UPDATE consultation<br/>SET status='acknowledged', disposition=@disposition, acknowledged_at=now()<br/>WHERE id=@cid AND requested_by=@actor_id",
    "    end",
    "",
    "    rect rgb(255,255,230)",
    "    Note over R,DB: Close Phase",
    "    R->>API: PUT /api/actions/{id}/consultations/{cid}/close (via BFF)",
    "    API->>DB: UPDATE consultation<br/>SET status='closed', closed_at=now()<br/>WHERE id=@cid AND requested_by=@actor_id",
    "    end",
    ""
  ],
