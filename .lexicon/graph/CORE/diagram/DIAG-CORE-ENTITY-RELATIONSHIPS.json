    "    }",
    "    WorkflowTransition {",
    "        uuid Id PK",
    "        uuid WorkflowDefinitionId FK",
    "        uuid FromStateId FK",
    "        uuid ToStateId FK",
    "        jsonb GuardExpression \"guard conditions\"",
    "    }",
    "    TenantSequence {",
    "        uuid TenantId PK",
    "        bigint CurrentValue \"next ACT-{n}\"",
    "    }",
    "    Language {",
