  "module_id": "01KXR2C3RACFENBCQ800YKK351",
  "ref_code": "DIAG-CORE-OVERDUE-DETECTION-PROCESS",
  "title": "Overdue Action Detection (Background Service)",
  "diagram_type": "workflow",
  "format": "mermaid",
  "content": [
    "flowchart TD",
    "    start([START: OverdueActionCheckerService runs on schedule])",
    "    s1[1. Query actions with regulatory deadlines<br/>SELECT actions, regulatory_deadlines<br/>WHERE action.state NOT IN terminal states<br/>AND regulatory_deadlines.status != 'met']",
    "",
    "    subgraph loop [\"For each deadline\"]",
    "        sa[a. Compare current time against deadline]",
    "        d1{\"Deadline breached?<br/>now > due_date\"}",
    "        breached[Mark action as overdue<br/>UPDATE actions SET is_overdue=true<br/>UPDATE regulatory_deadlines<br/>SET status='breached'<br/>Create overdue alert<br/>Record ActionAuditEvent<br/>event_type='deadline.breached']",
    "        d2{\"Deadline approaching?<br/>now > due_date - warning_window\"}",
    "        warning[Create warning notification<br/>UPDATE regulatory_deadlines<br/>SET status='warning'<br/>Record ActionAuditEvent<br/>event_type='deadline.warning']",
    "        sb[b. Update deadline status]",
    "        next([Continue to next deadline])",
    "",
    "        sa --> d1",
    "        d1 -->|Yes| breached --> next",
    "        d1 -->|No| d2",
    "        d2 -->|Yes| warning --> sb --> next",
    "        d2 -->|No| sb --> next",
    "    end",
    "",
    "    stop([END])",
    "",
    "    start --> s1 --> loop --> stop",
    ""
  ],
  "created_at": "2026-07-17T13:07:49.3495684+00:00"
