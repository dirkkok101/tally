  "ref_code": "NFR-INGEST-LOCAL-DATA-PROTECTION",
  "title": "Protect local statement and ingestion data",
  "description": [
    "Keep source, temporary, manifest, receipt, and diagnostic handling local, owner-only, passive, and payload-free."
  ],
  "category": "security",
  "target": "Zero source or financial payload disclosures in process arguments, logs, stderr, crash diagnostics, or telemetry; 100% of persisted INGEST directories and files use 0700 and 0600 respectively where supported; zero source modifications or retained source copies; 100% of success, failure, crash, abandonment, and startup-cleanup tests leave no orphan extraction temporary.",
  "load_condition": "Preview, review, commit, resume, status, abandon, and cleanup across success, expected failure, unexpected parser failure, and injected process termination.",
  "measurement": "Permission assertions, canary scans across stdout/stderr/logs/process arguments, before-and-after source hashes, and deterministic artifact inventory checks.",
  "rationale": [
    "Statements and manifests contain highly sensitive household financial data even in a single-owner local product."
  ],
