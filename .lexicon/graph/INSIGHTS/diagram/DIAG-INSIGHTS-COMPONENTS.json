    "  History --> Store[(insights.db active generation)]",
    "  Reports --> Store",
    "  Recovery --> Store",
    "  Recovery --> Generations[Verified generations and backups]",
    "  Channels[Future CHANNELS consumer] --> Registry",
    "  Bootstrap[Explicit InsightsExtensions registration] --> Registry",
