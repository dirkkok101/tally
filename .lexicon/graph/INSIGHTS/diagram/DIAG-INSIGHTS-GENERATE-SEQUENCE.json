{
  "id": "01KXZDY1T00W50687XJW0Q1C0P",
  "module_id": "01KXR4WNWDEV5WWPYPB8TQZBC4",
  "ref_code": "DIAG-INSIGHTS-GENERATE-SEQUENCE",
  "title": "Coherent deterministic report generation",
  "diagram_type": "sequence",
  "format": "mermaid",
  "content": [
    "sequenceDiagram",
    "  actor Caller",
    "  participant Registry as Operation Registry",
    "  participant Generate as GenerateInsightReportQuery",
    "  participant Compiler as InsightReportCompiler",
    "  participant BudgetClient as BudgetContractClient",
    "  participant Budget as BUDGET Composite",
    "  participant Ledger as LEDGER Snapshot",
    "  Caller->>Registry: insights.report.generate request",
    "  Registry->>Generate: validated typed request",
    "  Generate->>Generate: freeze TimeProvider and enforce limits",
    "  Generate->>BudgetClient: GetInsightEvidenceAsync",
    "  BudgetClient->>Budget: budget.insights.evidence.get",
    "  Budget->>Budget: resolve explicit planState",
    "  Budget->>Ledger: materialize one complete snapshot",
    "  Ledger-->>Budget: dated members plus exact total and snapshot identity",
    "  alt BoundRevision",
    "    Budget->>Budget: canonical BudgetPositionCalculator over same members",
    "    Budget-->>BudgetClient: plan plus position plus members",
    "  else NoBudgetPlan or NoActiveBudgetPlanRevision",
    "    Budget-->>BudgetClient: absence state plus members no position",
    "  end",
    "  BudgetClient-->>Generate: one bounded coherent public evidence result",
    "  Generate->>Compiler: compile normalized request and evidence",
    "  Compiler->>Compiler: reconcile windows metrics pace states explanations order fingerprint",
    "  Compiler-->>Generate: complete InsightReport",
    "  Generate-->>Registry: one ephemeral result no write",
    "  Registry-->>Caller: one stdout envelope"
  ],
