  "ref_code": "DIAG-INSIGHTS-STATE-ER",
  "title": "INSIGHTS durable state model",
  "diagram_type": "er",
  "format": "mermaid",
  "content": [
    "erDiagram",
    "  STORE_GENERATION ||--|| STORE_METADATA : contains",
    "  STORE_GENERATION ||--o{ REPORT_SNAPSHOT : owns",
    "  REPORT_SNAPSHOT ||--o| REPORT_PAYLOAD : contains",
    "  REPORT_SNAPSHOT ||--o| RESTATEMENT_LINK : child_has",
    "  REPORT_SNAPSHOT ||--o{ RESTATEMENT_LINK : predecessor_is_referenced_by",
    "  DELETION_EVENT ||--|| IDEMPOTENCY_RECORD : records",
    "  REPORT_SNAPSHOT ||--o{ IDEMPOTENCY_RECORD : outcome_ref",
    "  STORE_GENERATION ||--o{ IDEMPOTENCY_RECORD : owns",
    "  STORE_GENERATION ||--o{ RECOVERY_RECEIPT : records",
    "  REPORT_SNAPSHOT {",
    "    text snapshot_id PK",
    "    text report_id",
    "    text budget_period",
    "    text created_at",
    "    text actor",
    "    text reason",
    "    text content_fingerprint",
    "    text schema_version",
    "  }",
    "  REPORT_PAYLOAD {",
    "    text snapshot_id PK",
    "    blob canonical_json",
    "    text payload_fingerprint",
    "  }",
    "  RESTATEMENT_LINK {",
    "    text child_snapshot_id PK",
    "    text predecessor_snapshot_id FK",
    "  }",
    "  DELETION_EVENT {",
    "    text deletion_event_id PK",
    "    text deleted_snapshot_id",
    "    text deleted_at",
    "    text actor",
    "    text reason",
    "    text predecessor_snapshot_id",
    "  }",
    "  IDEMPOTENCY_RECORD {",
    "    text operation_id",
    "    text key_digest",
    "    text request_fingerprint",
    "    text outcome_kind",
    "    text outcome_ref",
    "  }"
  ],
