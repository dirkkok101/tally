  "ref_code": "DM-LEDGER-FINANCIAL-RELATIONSHIP",
  "name": "FinancialRelationshipAndLifecycle",
  "description": [
    "Explicit active or retired transfer/refund classification with typed roles and attributable correction."
  ],
  "schema_def": [
    "financial_relationship",
    "- id: ULID text, primary key",
    "- type: enum {transfer,refund}",
    "- sourceTransactionId: TransactionFact.id, RESTRICT",
    "- targetTransactionId: TransactionFact.id, RESTRICT",
    "- amountMinor: positive Int64",
    "- state: enum {active,retired}",
    "- createdAt and actorContext",
    "relationship_lifecycle_event",
    "- id: ULID text, primary key",
    "- relationshipId: FinancialRelationship.id, RESTRICT",
    "- eventType: enum {revoked,replaced}",
    "- replacementRelationshipId: nullable relationship reference",
    "- reason: text, required",
    "- occurredAt and actorContext",
    "Constraints: distinct active transactions; transfer has exactly one outflow and one inflow across distinct owned accounts with equal principal; refund names original debit and refund credit and respects cumulative magnitude; transaction roles are exclusive; revoke/replace retires atomically."
  ],
