  "name": "TransactionFact",
  "description": [
    "Canonical immutable bank-account movement. Signed amount is the owned-account balance delta."
  ],
  "schema_def": [
    "transaction_fact",
    "- id: ULID text, primary key",
    "- accountId: Account.id, required, RESTRICT",
    "- signedAmountMinor: Int64, required, non-zero",
    "- currencyCode: literal ZAR",
    "- transactionDate: ISO local date, required",
    "- postingDate: ISO local date, nullable",
    "- effectiveDate: derived postingDate ?? transactionDate",
    "- originalDescription: text, required",
    "- sourceReference: text, nullable",
    "- provenanceKind: enum {manual_agent,statement_import,other}",
    "- provenanceReference: text, nullable",
    "- recordedAt: trusted UTC instant",
    "- recordedByOsIdentity: text, protected metadata",
    "Constraints: insert-only; no category or relationship columns; one source reference per account when present; amounts originate from canonical two-decimal strings."
  ],
