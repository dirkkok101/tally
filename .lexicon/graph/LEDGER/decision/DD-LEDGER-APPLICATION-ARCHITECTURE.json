{
  "id": "01KXSWZ6JRE2EA51AG7K4M4B5V",
  "module_id": "01KXR4WN5YEX7RT6D1GJ30SCJN",
  "ref_code": "DD-LEDGER-APPLICATION-ARCHITECTURE",
  "title": "Single-process provider-neutral vertical slices with selective ports",
  "description": [
    "Define the internal application shape and the boundary between LEDGER, sibling Tally modules, Hermes, and other external callers."
  ],
  "decision": [
    "Ship one local Native-AOT CLI process with concrete Contracts, Features, Domain, Storage, and Bootstrap zones. Use explicit command/query handlers and only two destructive host ports. Keep every provider, transport, orchestration, schedule, delivery, and human-channel concern outside LEDGER."
  ],
  "rationale": [
    "A single-owner local system needs deterministic process contracts and transactional storage, not a service topology. Explicit vertical slices keep evidence, reconciliation, dimensions, actuals, and recovery cohesive while stable CLI schemas make every caller equal."
  ],
  "alternatives": [
    "Rejected HTTP or daemon hosting because it expands the trust and operational boundary. Rejected repositories, mediator, event bus, generic unit of work, and provider gateways because no second implementation exists. Rejected direct Hermes, AgentMail, or WhatsApp integration because ADR-CORE-0030 assigns orchestration externally."
  ],
  "consequences": [
    "LEDGER remains offline and channel-neutral. INGEST orchestrates statement batches and Hermes orchestrates transports. New behavior is added through explicit operations and vertical slices. The application is single-writer by contract."
  ],
  "status_notes": [
    "Revised for provider-neutral evidence, reconciliation, independent financial dimensions, and ADR-CORE-0030."
  ],
  "status": "accepted",
