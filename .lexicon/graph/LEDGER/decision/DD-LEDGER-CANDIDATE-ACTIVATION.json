{
  "id": "01KXSWZ8G4C5KRNNJCGMJSMHTZ",
  "module_id": "01KXR4WN5YEX7RT6D1GJ30SCJN",
  "ref_code": "DD-LEDGER-CANDIDATE-ACTIVATION",
  "title": "Verified store generations with atomic pointer activation",
  "description": [
    "Define safe activation for restored or migrated authoritative store generations."
  ],
  "decision": [
    "Prepare candidates outside the current generation; validate schema, integrity, all durable counts and invariants, exact totals and dimensional groups, evidence uniqueness, decision/link state, coverage, histories, and idempotency; then atomically replace an owner-private CURRENT pointer using expected fingerprints and explicit replacement authorization."
  ],
  "rationale": [
    "A restore or migration must never partially replace the source of truth. Expanded Reconciliation State is just as canonical as transaction amounts."
  ],
  "alternatives": [
    "Rejected in-place restore or migration, directory copying over the current store, activation without a manifest, and validation that checks only SQLite integrity."
  ],
  "consequences": [
    "Prepare and activate remain distinct idempotent operations. The prior generation remains a recovery point. Manifests enumerate every durable type and exact invariant."
  ],
  "status_notes": [
    "Expanded verification manifest for evidence, reconciliation, coverage, payment attribution, pools, and dimensional totals."
  ],
  "status": "accepted",
