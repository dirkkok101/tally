{
  "id": "01KXSWZ691B67MGFHJNAQ12FPF",
  "module_id": "01KXR4WN5YEX7RT6D1GJ30SCJN",
  "ref_code": "DD-LEDGER-CLI-OPERATION-CONTRACT",
  "title": "Explicit provider-neutral resource commands from one registry",
  "description": [
    "Define the stable automation boundary used equally by Hermes, sibling modules, and direct local callers."
  ],
  "decision": [
    "Generate CLI paths, operation IDs, help, schemas, descriptors, and compatibility checks from one explicit registry. Give evidence, reconciliation candidates and dispositions, decision lifecycle, statement coverage, payment attribution, Spend Pools, actuals, and recovery their own closed typed operations. Reject unknown fields and generic invocation or batch payloads."
  ],
  "rationale": [
    "Explicit operations make mutation authority, idempotency, privacy, errors, and versioning auditable. Per-evidence atomic commands keep Ledger safe without stealing INGEST batch responsibilities."
  ],
  "alternatives": [
    "Rejected a generic invoke or open metadata bag because it hides capability and permits provider vocabulary. Rejected minimal evaluate/apply/resolve because it overloads outcomes. Rejected Ledger-owned statement batch commands because INGEST owns that lifecycle."
  ],
  "consequences": [
    "The operation registry is a completeness gate. Every public operation requires a typed contract and process test. Schema discovery works without a skill. New commands expand the registry deliberately rather than through aliases."
  ],
  "status_notes": [
    "Expanded for evidence, reconciliation, coverage, attribution, pools, and channel-neutral external callers."
  ],
  "status": "accepted",
