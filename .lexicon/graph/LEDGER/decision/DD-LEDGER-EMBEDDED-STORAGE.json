{
  "id": "01KXSWZ6WJJ89QZ0KYCV9EPTV7",
  "module_id": "01KXR4WN5YEX7RT6D1GJ30SCJN",
  "ref_code": "DD-LEDGER-EMBEDDED-STORAGE",
  "title": "Raw SQLite with host-managed at-rest protection",
  "description": [
    "Select durable local persistence and the host-protection boundary for all canonical financial state."
  ],
  "decision": [
    "Use raw Microsoft.Data.Sqlite with foreign keys, WAL, synchronous FULL, ordered immutable migrations, one exclusive writer, and owner-private generation directories. Require a host-encrypted volume and 0700 or 0600 artifacts. Store allowlisted privacy-conscious evidence metadata only."
  ],
  "rationale": [
    "SQLite gives atomic local durability and recovery without a server. Raw SQL keeps constraints and transactions explicit. Host-managed encryption avoids claiming protection stock SQLite does not provide."
  ],
  "alternatives": [
    "Rejected PostgreSQL, EF Core, and a hosted database as unnecessary operational surface. Rejected custom application cryptography and storing source payloads. Rejected multiple writers because reconciliation and recovery require a simple authority boundary."
  ],
  "consequences": [
    "All durable types, including evidence, decisions, coverage, attribution, and pools, participate in migrations, backup, validation, and recovery. Production requires independent host-encryption evidence."
  ],
  "status_notes": [
    "Expanded durable scope; persistence technology and security boundary unchanged."
  ],
  "status": "accepted",
