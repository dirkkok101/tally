{
  "id": "01KXSWZ777TWQFAG7VCDVNPK3H",
  "module_id": "01KXR4WN5YEX7RT6D1GJ30SCJN",
  "ref_code": "DD-LEDGER-FINANCIAL-REPRESENTATION",
  "title": "Canonical ZAR minor units and local dates",
  "description": [
    "Define exact money, sign, currency, and date semantics shared by facts, evidence observations, matching, and actuals."
  ],
  "decision": [
    "Represent ZAR as signed Int64 minor units and public money as canonical decimal strings. Interpret sign as owner economic-position delta. Use transaction date as Effective Date and preserve a distinct supplied posting date. Matching compares normalized exact values under a versioned policy."
  ],
  "rationale": [
    "Exact integers prevent rounding drift. One sign convention makes movements, refunds, transfers, pool/category groups, and statement compatibility deterministic."
  ],
  "alternatives": [
    "Rejected floating point, provider debit-credit vocabulary in public contracts, inferred exchange rates, and silently substituting posting date."
  ],
  "consequences": [
    "Parsing rejects numeric JSON money, excessive scale, overflow, negative zero, and unsupported currency. Any tolerance for reconciliation must be explicit, empirically validated, versioned, and recorded in the match basis."
  ],
  "status_notes": [
    "Applied unchanged core representation to reconciliation evidence and dimensional actuals."
  ],
  "status": "accepted",
