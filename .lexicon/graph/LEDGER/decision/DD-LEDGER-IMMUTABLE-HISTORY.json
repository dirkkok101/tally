  "module_id": "01KXR4WN5YEX7RT6D1GJ30SCJN",
  "ref_code": "DD-LEDGER-IMMUTABLE-HISTORY",
  "title": "Immutable facts, evidence, decisions, and append-only lifecycle history",
  "description": [
    "Define correction semantics for canonical facts and every financial classification or reconciliation dimension."
  ],
  "decision": [
    "Keep transaction facts insert-only. Record void and supersession, catalogue lifecycle, category allocation, payment attribution, spend-pool assignment, evidence links, reconciliation decisions, statement coverage, transfers, and refunds as attributable append-only history. Derive current state from active history; never overwrite or silently move links or assignments."
  ],
  "rationale": [
    "Financial corrections must remain explainable, reversible, and recoverable. Reconciliation needs proof of deterministic versus owner-approved choices and their exact reasons."
  ],
  "alternatives": [
    "Rejected mutable provenance flags, a single source reference, overwriting assignments, deleting decisions, and automatically inheriting evidence or dimensions across supersession."
  ],
  "consequences": [
    "Queries and recovery validation resolve active history. Corrections require explicit operations. Storage is larger but auditability and replay safety are preserved."
  ],
  "status_notes": [
    "Expanded beyond transaction and category history to provider-neutral evidence, reconciliation, payment attribution, pools, and coverage."
  ],
  "status": "accepted",
