{
  "id": "01KXSWZ7J9GPCEHT6NPRX2M79C",
  "module_id": "01KXR4WN5YEX7RT6D1GJ30SCJN",
  "ref_code": "DD-LEDGER-IMMUTABLE-HISTORY",
  "title": "Immutable financial facts with append-only lifecycle history",
  "description": [
    "Shape corrections, allocations, transfers, refunds, and attributable history."
  ],
  "decision": [
    "Transaction facts are insert-only. Void and supersede append TransactionLifecycleEvent rows; supersession creates a new transaction and never silently transfers relationships. Category changes append CategoryAllocation rows and retire the prior active allocation. Transfer and refund confirmations create typed FinancialRelationship rows with explicit roles and amount; revoke and replace append RelationshipLifecycleEvent rows and retire the prior active relationship. Application commands enforce role cardinality, conservation, exclusivity, lifecycle, and cumulative-refund rules inside one SQLite transaction with the idempotency outcome."
  ],
  "rationale": [
    "Mutable source facts or inferred relationships would destroy auditability and make actuals non-reproducible. Narrow typed commands preserve the PRD rules and keep historical references valid."
  ],
  "alternatives": [
    "A: update transaction/category columns in place — rejected. B: general event sourcing — rejected as excessive. C: immutable facts plus explicit lifecycle/history tables — chosen."
  ],
  "consequences": [
    "No public hard delete. Retired history remains queryable and included in Durable Ledger State. Archival blocks new use but does not break old references. Actuals use only active lifecycle/allocation/relationship state as of the query snapshot."
  ],
  "status_notes": [
    "Accepted architecture, conditionally gated: OQ-LEDGER-5 and OQ-LEDGER-6 must be resolved from representative real-account examples before relationship policy or category-allocation implementation starts. Invalid evidence updates this decision and its models/contracts first. Planned areas: src/Tally/Features/Ledger/Transactions and Relationships."
  ],
  "status": "accepted",
