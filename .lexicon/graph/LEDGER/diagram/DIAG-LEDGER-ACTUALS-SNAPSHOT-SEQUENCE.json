{
  "id": "01KXSX90E8X7KP08ZBGFE76MPQ",
  "module_id": "01KXR4WN5YEX7RT6D1GJ30SCJN",
  "ref_code": "DIAG-LEDGER-ACTUALS-SNAPSHOT-SEQUENCE",
  "title": "Cross-process actuals snapshot pagination",
  "diagram_type": "sequence",
  "format": "mermaid",
  "content": [
    "sequenceDiagram",
    "  participant A as Agent",
    "  participant Q1 as First tally process",
    "  participant DB as SQLite",
    "  participant Q2 as Later tally process",
    "  A->>Q1: actuals query with filters and page size",
    "  Q1->>DB: acquire writer lock; BEGIN IMMEDIATE",
    "  alt store busy before transaction",
    "    DB-->>Q1: busy",
    "    Q1-->>A: LEDGER-SNAPSHOT-BUSY, no cursor",
    "  else transaction acquired",
    "    DB-->>Q1: coherent active facts, allocations, relationships",
    "    Q1->>Q1: exact classifications, totals, stable projection",
    "    Q1->>DB: insert snapshot and ordered items",
    "    alt crash, cancellation, or write failure",
    "      DB-->>DB: rollback; no partial snapshot",
    "    else commit succeeds",
    "      Q1->>DB: COMMIT",
    "      Q1-->>A: first page, totals, opaque cursor, expiry",
    "    end",
    "  end",
    "  Note over Q1: process exits",
    "  A->>Q2: actuals query with cursor only",
    "  Q2->>DB: read-only validate cursor versions, generation, expiry",
    "  DB-->>Q2: fixed ordinal projection",
    "  Q2-->>A: stable next page",
    "  Note over DB: snapshots are ephemeral and excluded from backup"
  ],
