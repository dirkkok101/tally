  "ref_code": "DIAG-LEDGER-MUTATION-SEQUENCE",
  "title": "Idempotent Ledger mutation sequence",
  "diagram_type": "sequence",
  "format": "mermaid",
  "content": [
    "sequenceDiagram",
    "  participant A as Agent",
    "  participant C as CLI Adapter",
    "  participant R as Operation Registry",
    "  participant H as Typed Command Handler",
    "  participant D as LedgerDb",
    "  A->>C: command, contract, idempotency key, JSON",
    "  C->>R: resolve descriptor and schema",
    "  R-->>C: concrete request and handler",
    "  C->>H: validated command plus actor",
    "  H->>D: begin exclusive write transaction",
    "  D-->>H: prior idempotency outcome or state",
    "  alt identical replay",
    "    H-->>C: original stable result",
    "  else changed request for same identity",
    "    H-->>C: conflict result",
    "  else new valid mutation",
    "    H->>H: apply pure policies",
    "    H->>D: facts plus history plus idempotency result",
    "    D-->>H: commit exactly once",
    "    H-->>C: stable success",
    "  end",
    "  C-->>A: one stdout envelope and exit category"
  ],
