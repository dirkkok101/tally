  "ref_code": "DIAG-LEDGER-MUTATION-SEQUENCE",
  "title": "Idempotent logical-effect mutation sequence",
  "diagram_type": "sequence",
  "format": "mermaid",
  "content": [
    "sequenceDiagram",
    "  participant Caller",
    "  participant CLI",
    "  participant Handler",
    "  participant Policy",
    "  participant DB as LedgerDb",
    "",
    "  Caller->>CLI: typed mutation + idempotency key",
    "  CLI->>CLI: validate envelope, closed schema, privacy",
    "  CLI->>Handler: concrete command + CancellationToken",
    "  Handler->>DB: BEGIN IMMEDIATE",
    "  DB-->>Handler: replay or logical-identity conflict check",
    "  alt identical committed replay",
    "    Handler-->>CLI: stored stable result",
    "  else new effect",
    "    Handler->>Policy: validate lifecycle and invariants",
    "    Policy-->>Handler: deterministic result or stable error",
    "    Handler->>DB: append facts/history/effects + outcome",
    "    Handler->>DB: COMMIT atomically",
    "    Handler-->>CLI: typed result",
    "  end",
    "  CLI-->>Caller: one stdout envelope; safe stderr metadata",
    ""
  ],
