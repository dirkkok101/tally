  "module_id": "01KXR4WN5YEX7RT6D1GJ30SCJN",
  "ref_code": "DIAG-LEDGER-RECONCILIATION-SEQUENCE",
  "title": "Match-first statement reconciliation sequence",
  "diagram_type": "sequence",
  "format": "mermaid",
  "content": [
    "sequenceDiagram",
    "  participant Ingest as INGEST",
    "  participant CLI as LEDGER CLI",
    "  participant Recon as Reconciliation handler",
    "  participant DB as LedgerDb",
    "",
    "  Ingest->>CLI: evidence.register approved statement row",
    "  CLI->>DB: commit evidence or return identical logical replay",
    "  Ingest->>CLI: reconciliation.candidates evidenceId + policy",
    "  CLI->>DB: read active unreconciled compatible state",
    "  DB-->>Ingest: candidates, rejections, conflicts, advisory token",
    "  Ingest->>CLI: reconciliation.apply closed disposition",
    "  CLI->>Recon: typed request",
    "  Recon->>DB: BEGIN IMMEDIATE and revalidate current state",
    "  alt strong unique match and validated policy",
    "    Recon->>DB: append deterministic decision + confirming link",
    "  else no candidate and no guard candidate",
    "    Recon->>DB: create statement-only fact + decision + link",
    "  else ambiguous or exception",
    "    Recon->>DB: append reviewable decision/exception only",
    "  end",
    "  Recon->>DB: commit effect + idempotency outcome",
    "  DB-->>Ingest: structured outcome",
    "  Ingest->>CLI: coverage.complete scope + expected evidence",
    "  CLI->>DB: derive exact counts, absent prior facts, exceptions",
    "  DB-->>Ingest: batch summary and exception list",
    ""
  ],
