  "content": [
    "stateDiagram-v2",
    "  [*] --> RecordedUnreconciled: canonical fact recorded",
    "  [*] --> StatementOnly: statement evidence creates fact",
    "  RecordedUnreconciled --> StatementReconciled: validated deterministic match",
    "  RecordedUnreconciled --> OwnerConfirmedMatch: explicit owner-confirmed match",
    "  RecordedUnreconciled --> AmbiguousMatch: multiple or unsafe candidates",
    "  RecordedUnreconciled --> ReconciliationException: incompatible or policy error",
    "  RecordedUnreconciled --> RecordedAbsentFromStatement: completed scope has no confirming row",
    "  AmbiguousMatch --> OwnerConfirmedMatch: owner confirms candidate",
    "  AmbiguousMatch --> StatementOnly: owner confirms no prior fact",
    "  AmbiguousMatch --> ReconciliationException: owner rejects candidates",
    "  StatementReconciled --> RecordedUnreconciled: decision revoked",
    "  OwnerConfirmedMatch --> RecordedUnreconciled: decision revoked",
    "  StatementOnly --> ReconciliationException: decision replaced after correction",
    "  RecordedAbsentFromStatement --> StatementReconciled: coverage or evidence corrected",
