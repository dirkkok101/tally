  "ref_code": "DIAG-LEDGER-RECOVERY-WORKFLOW",
  "title": "Verified restore and evolution activation",
  "diagram_type": "workflow",
  "format": "mermaid",
  "content": [
    "flowchart TD",
    "  Start[Prepare request] --> Lock[Acquire writer lock and fingerprint current]",
    "  Lock --> Candidate[Create private candidate generation]",
    "  Candidate --> Build[Restore or apply ordered migrations]",
    "  Build --> Verify[Integrity, foreign keys, versions, counts, totals, history, relationships, idempotency]",
    "  Verify -->|fail| Reject[Reject candidate; CURRENT unchanged]",
    "  Verify -->|pass| Manifest[Flush candidate and immutable manifest]",
    "  Manifest --> Return[Return candidate ID and fingerprint]",
    "  Return --> Authorize[Activate with explicit authorization and expected current fingerprint]",
    "  Authorize --> Recheck[Reacquire lock and revalidate]",
    "  Recheck -->|changed or invalid| Reject",
    "  Recheck --> Switch[Atomically replace and fsync CURRENT pointer]",
    "  Switch --> Recovery[Retain previous generation as recovery point]",
    "  Recovery --> Done[Verified candidate is authoritative]"
  ],
